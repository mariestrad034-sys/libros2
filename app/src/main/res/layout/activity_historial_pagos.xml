<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/colorFondo">

    <!-- Encabezado -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💰 Historial de Pagos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextoPrincipal"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="25dp" />

    <!-- Texto informativo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Préstamos pendientes de pago:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextoPrincipal"
        android:layout_marginBottom="15dp" />

    <!-- ScrollView con la lista de préstamos -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:id="@+id/containerPagos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Botón volver -->
    <Button
        android:id="@+id/btnVolverHistorial"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="⬅️ Volver"
        android:backgroundTint="#757575"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>