<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/colorFondo">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚 Catálogo de Libros"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextoPrincipal"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <Spinner
        android:id="@+id/spinnerGeneros"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@android:drawable/btn_dropdown"
        android:layout_marginBottom="15dp" />

    <!-- NUEVO COMPONENTE: Buscador adaptado para Modo Oscuro -->
    <EditText
        android:id="@+id/etBuscarTitulo"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="🔍 Buscar por título..."
        android:background="@android:drawable/editbox_background"
        android:backgroundTint="@color/colorTarjeta"
        android:textColor="@color/colorTextoPrincipal"
        android:textColorHint="@color/colorTextoSecundario"
        android:paddingLeft="15dp"
        android:inputType="text"
        android:layout_marginBottom="15dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerLibros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp" />

    </ScrollView>
</LinearLayout>